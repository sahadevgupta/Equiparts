<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Equiparts.MainPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False">

    <!-- ✅ GRID ROOT -->
    <Grid Padding="12" Margin="4"
          RowDefinitions="Auto,Auto,*"
          RowSpacing="10">

        <!-- ✅ HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="#0B2A4A"
              Padding="12">

            <Label 
                Text="Equiparts Groups"
                TextColor="White"
                FontSize="20"
                FontAttributes="Bold"/>
        </Grid>

        <!-- ✅ SEARCH -->
        <Border Grid.Row="1" Padding="10">

            <Entry 
                Placeholder="Search Sub Category"
                Text="{Binding SearchText}" />

        </Border>

        <!-- ✅ GROUPED LIST -->
        <CollectionView
            Grid.Row="2"
            ItemsSource="{Binding GroupedItems}"
            IsGrouped="True"
            VerticalOptions="FillAndExpand"
            Margin="8">

            <!-- ✅ CATEGORY HEADER -->
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate>
                    <Label
                        Text="{Binding CategoryName}"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="#0B2A4A"
                        Margin="5,12,5,5"/>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>

            <!-- ✅ ITEM TEMPLATE -->
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="5"
                            Padding="10"
                            Stroke="#F47C20"
                            StrokeThickness="3">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>

                        <Label
                            Text="{Binding Name}"
                            TextColor="Black"
                            FontAttributes="Bold"
                            FontSize="14"/>

                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>
