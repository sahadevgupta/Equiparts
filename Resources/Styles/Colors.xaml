<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <!-- Primary Brand -->
    <Color x:Key="Primary">#0E2346</Color>
    <Color x:Key="PrimaryDark">#08152C</Color>
    <Color x:Key="PrimaryLight">#19355F</Color>

    <!-- Accent -->
    <Color x:Key="Accent">#F58220</Color>
    <Color x:Key="AccentDark">#D96D0D</Color>
    <Color x:Key="AccentLight">#FFA247</Color>

    <!-- Background -->
    <Color x:Key="PageBackground">#F7F8FA</Color>

    <!-- Card -->
    <Color x:Key="CardBackground">White</Color>

    <!-- Text -->
    <Color x:Key="TitleText">#12213F</Color>
    <Color x:Key="BodyText">#666666</Color>
    <Color x:Key="PriceText">#F58220</Color>

    <!-- Divider -->
    <Color x:Key="Divider">#E5E7EB</Color>

    <!-- Border -->
    <Color x:Key="Border">#ECECEC</Color>

    <!-- Success -->
    <Color x:Key="Success">#2DB84D</Color>
</ResourceDictionary>