<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="Equiparts.Views.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:Equiparts.ViewModels"
    xmlns:models="clr-namespace:Equiparts.Models"
    x:DataType="viewModels:HomeViewModel"
    BackgroundColor="{StaticResource PageBackground}"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid
            Padding="20,20,20,10"
            BackgroundColor="{StaticResource Primary}">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Image
                HeightRequest="45"
                Source="logo.png"
                WidthRequest="45"/>

            <VerticalStackLayout
                Grid.Column="1"
                Margin="15,0"
                VerticalOptions="Center">

                <Label
                    FontAttributes="Bold"
                    FontSize="20"
                    Text="Equiparts"
                    TextColor="White"/>

                <Label
                    FontSize="13"
                    Opacity="0.8"
                    Text="Heavy Equipment Parts"
                    TextColor="White"/>
            </VerticalStackLayout>

            <Image
                Grid.Column="2"
                HeightRequest="26"
                Source="notification.png"
                WidthRequest="26"/>
        </Grid>

        <!-- Body -->
        <ScrollView Grid.Row="1">

            <VerticalStackLayout Padding="16"
                    Spacing="20">

                <!-- Search -->

                <Border
                    Padding="12"
                    BackgroundColor="White"
                    Stroke="{StaticResource Border}"
                    StrokeShape="RoundRectangle 12">

                    <Grid ColumnDefinitions="30,*">

                        <Image
                            HeightRequest="20"
                            Source="search.png"
                            WidthRequest="20"/>

                        <Entry
                            Grid.Column="1"
                            Placeholder="Search products..."
                            PlaceholderColor="Gray"/>

                    </Grid>

                </Border>

                <!-- Categories -->

                <Label
                    StyleClass="SectionTitle"
                    Text="Categories"/>

                <CollectionView
                    HeightRequest="120"
                    ItemsSource="{Binding Categories}"
                    ItemsLayout="HorizontalList"
                    SelectionMode="Single"
                    SelectedItem="{Binding SelectedCategory}">

                    <CollectionView.ItemTemplate>

                        <DataTemplate x:DataType="models:Category">

                            <VerticalStackLayout
                                Margin="5"
                                HorizontalOptions="Center">

                                <Border
                                    Padding="15"
                                    BackgroundColor="White"
                                    Stroke="{StaticResource Border}"
                                    StrokeShape="RoundRectangle 15">

                                    <Image
                                        HeightRequest="55"
                                        Source="{Binding Image}"
                                        WidthRequest="55"/>

                                </Border>

                                <Label
                                    Margin="0,8,0,0"
                                    FontAttributes="Bold"
                                    FontSize="13"
                                    HorizontalTextAlignment="Center"
                                    Text="{Binding Name}"
                                    WidthRequest="95"/>

                            </VerticalStackLayout>

                        </DataTemplate>

                    </CollectionView.ItemTemplate>

                </CollectionView>

                <!-- Banner -->

                <CarouselView HeightRequest="180">

                    <CarouselView.ItemsSource>

                        <x:Array Type="{x:Type x:String}">
                            <x:String>banner1.png</x:String>
                            <x:String>banner2.png</x:String>
                            <x:String>banner3.png</x:String>
                        </x:Array>

                    </CarouselView.ItemsSource>

                    <CarouselView.ItemTemplate>

                        <DataTemplate>

                            <Border
                                Margin="0,0,0,10"
                                StrokeShape="RoundRectangle 18">

                                <Image
                                    Aspect="AspectFill"
                                    Source="{Binding}"/>

                            </Border>

                        </DataTemplate>

                    </CarouselView.ItemTemplate>

                </CarouselView>

                <!-- Best Seller -->

                <Grid ColumnDefinitions="*,Auto">

                    <Label
                        StyleClass="SectionTitle"
                        Text="Best Sellers"/>

                    <Label
                        Grid.Column="1"
                        FontAttributes="Bold"
                        Text="View All"
                        TextColor="{StaticResource Accent}"/>

                </Grid>

                <CollectionView
                    ItemsSource="{Binding BestSellers}"
                    SelectionMode="None">

                    <CollectionView.ItemsLayout>

                        <GridItemsLayout
                            Orientation="Vertical"
                            Span="2"/>

                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>

                        <DataTemplate x:DataType="models:Product">

                            <Border
                                Margin="5"
                                Padding="10"
                                BackgroundColor="White"
                                Stroke="{StaticResource Border}"
                                StrokeShape="RoundRectangle 18">

                                <VerticalStackLayout>

                                    <Image
                                        Aspect="AspectFit"
                                        HeightRequest="120"
                                        Source="{Binding Image}"/>

                                    <Label
                                        Margin="0,10,0,0"
                                        FontAttributes="Bold"
                                        FontSize="15"
                                        LineBreakMode="TailTruncation"
                                        Text="{Binding Name}"/>

                                    <Label
                                        FontSize="12"
                                        LineBreakMode="TailTruncation"
                                        MaxLines="2"
                                        Opacity="0.7"
                                        Text="{Binding Description}"/>

                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="18"
                                        Text="{Binding Price,StringFormat='₹ {0:F0}'}"
                                        TextColor="{StaticResource Accent}"/>

                                    <Button
                                        Margin="0,10,0,0"
                                        BackgroundColor="{StaticResource Accent}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:HomeViewModel}}, Path=AddToCartCommand}"
                                        CommandParameter="{Binding .}"
                                        CornerRadius="12"
                                        HeightRequest="40"
                                        Text="Add To Cart"
                                        TextColor="White"/>

                                </VerticalStackLayout>

                            </Border>

                        </DataTemplate>

                    </CollectionView.ItemTemplate>

                </CollectionView>

            </VerticalStackLayout>

        </ScrollView>

    </Grid>

</ContentPage>